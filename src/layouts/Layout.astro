---
import '../assets/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  noIndex: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonicalUrl, noIndex, jsonLd = [] } = Astro.props;
const whatsappHref = `https://wa.me/60196505050?text=${encodeURIComponent("Hi Perlette Cakes! I'd like to enquire about a custom cake order.")}`;

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "@id": "https://perlettecakes.com/#business",
  name: "Perlette Cakes",
  url: "https://perlettecakes.com/",
  telephone: "+60196505050",
  description:
    "Home-based baker making custom celebration cakes, cupcakes, cookies, and pastries for delivery across Klang Valley, Malaysia. Order via WhatsApp.",
  areaServed: "Klang Valley, Malaysia",
  sameAs: [
    "https://www.instagram.com/perlettecakes",
  ],
  potentialAction: {
    "@type": "OrderAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://wa.me/60196505050",
      actionPlatform: "https://schema.org/DesktopWebPlatform",
      inLanguage: "en",
    },
    deliveryMethod: {
      "@type": "DeliveryMethod",
      name: "Third-party delivery (Lalamove)",
    },
  },
};
 
// Merge business schema with any page-specific schemas
const allJsonLd = [
  businessJsonLd,
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];

---

<!doctype html>
<html lang="en">
	<head>
		<title>{title}</title>
		<meta name="description" content={description}>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="language" content="English" />
		<link rel="canonical" href={canonicalUrl} />
		{noIndex ? 
			(<meta name="robots" content="noindex, nofollow" />) : 
			(<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />)
		}

		{allJsonLd.map((schema) => (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}

	</head>
	<body>
		<div class="site-shell">
			<header class="site-nav">
				<div class="site-nav__inner content-shell">
					<a class="site-nav__brand" href="/">perlette cakes</a>
					<a class="site-nav__cta button button--primary" href={whatsappHref} target="_blank" rel="noreferrer">
						Order on WhatsApp
					</a>
				</div>
			</header>
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}

	.site-shell {
		min-height: 100vh;
	}

	.site-nav {
		position: sticky;
		top: 0;
		z-index: 20;
		padding-block: var(--space-md);
		background: var(--color-nav-surface);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--color-nav-border);
	}

	.site-nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
	}

	.site-nav__brand {
		color: var(--color-primary-ink);
		font-family: var(--font-display);
		font-size: var(--step-1);
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.04em;
		text-transform: lowercase;
		text-decoration: none;
		white-space: nowrap;
	}

	.site-nav__cta {
		min-height: 2.9rem;
		padding-inline: 1.1rem;
		flex-shrink: 0;
	}

	@media (min-width: 48rem) {
		.site-nav {
			padding-block: var(--space-lg);
		}

		.site-nav__brand {
			font-size: var(--step-2);
		}

		.site-nav__cta {
			padding-inline: 1.35rem;
		}
	}
</style>
