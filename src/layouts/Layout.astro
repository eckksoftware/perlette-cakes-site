---
import '../assets/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  noIndex: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonicalUrl, noIndex, jsonLd = [] } = Astro.props;

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "@id": "https://perlettecakes.com/#business",
  name: "Perlette Cakes",
  url: "https://perlettecakes.com/",
  telephone: "+60196505050",
  email: "Amiralorr@gmail.com",
  description:
    "Home-based cake bakery in Kuala Lumpur specialising in custom cakes, pastries, and cookies. Order via WhatsApp for delivery across KL and Selangor.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Kuala Lumpur",
    addressRegion: "Kuala Lumpur",
    addressCountry: "MY",
  },
  areaServed: [
    {
      "@type": "City",
      name: "Kuala Lumpur",
    },
    {
      "@type": "State",
      name: "Selangor",
    },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
      opens: "09:00",
      closes: "18:00",
    },
  ],
  sameAs: [
    "https://www.instagram.com/perlettecakes",
  ],
  priceRange: "$$",
  currenciesAccepted: "MYR",
  paymentAccepted: "Bank Transfer, Online Payment",
  potentialAction: {
    "@type": "OrderAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://wa.me/60196505050",
      actionPlatform: "https://schema.org/DesktopWebPlatform",
      inLanguage: "en",
    },
    deliveryMethod: {
      "@type": "DeliveryMethod",
      name: "Third-party delivery (Lalamove)",
    },
  },
};
 
// Merge business schema with any page-specific schemas
const allJsonLd = [
  businessJsonLd,
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];

---

<!doctype html>
<html lang="en">
	<head>
		<title>{title}</title>
		<meta name="description" content={description}>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="language" content="English" />
		<meta name="geo.region" content="MY-14" />
		<meta name="geo.placename" content="Kuala Lumpur" />
		<link rel="canonical" href={canonicalUrl} />
		{noIndex ? 
			(<meta name="robots" content="noindex, nofollow" />) : 
			(<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />)
		}

		{allJsonLd.map((schema) => (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}

	</head>
	<body>
		<div class="site-shell">
			<header class="site-nav">
				<div class="site-nav__inner content-shell">
					<a class="site-nav__brand" href="/">perlette cakes</a>
					<button class="site-nav__menu" type="button" aria-label="Open site menu">Menu</button>
				</div>
			</header>
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}

	.site-shell {
		min-height: 100vh;
	}

	.site-nav {
		position: sticky;
		top: 0;
		z-index: 20;
		padding-block: var(--space-md);
		background: rgba(255, 253, 251, 0.92);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(122, 74, 87, 0.12);
	}

	.site-nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
	}

	.site-nav__brand {
		font-size: var(--step-0);
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: lowercase;
		text-decoration: none;
		white-space: nowrap;
	}

	.site-nav__menu {
		padding: 0.85rem 1.2rem;
		border: 1px solid var(--color-primary-ink);
		background: var(--color-surface);
		color: var(--color-primary-ink);
		font-size: var(--step--1);
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
	}

	@media (min-width: 48rem) {
		.site-nav {
			padding-block: var(--space-lg);
		}

		.site-nav__menu {
			padding-inline: 1.5rem;
		}
	}
</style>
