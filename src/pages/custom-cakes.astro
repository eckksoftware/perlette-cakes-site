---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/shared/Breadcrumbs.astro';
import SignatureBand from '@components/shared/SignatureBand.astro';
import Collage from '@components/shared/Collage.astro';
import CategoryCta from '@components/shared/CategoryCta.astro';
import RelatedLinks from '@components/shared/RelatedLinks.astro';
import { categoryBySlug, categoryPath, categoryUrl } from '@data/catalogue';
import {
  SITE_ORIGIN,
  breadcrumbSchema,
  collectionPageSchema,
  itemListSchema,
} from '@lib/schema';

const category = categoryBySlug('custom-cakes');
const path = categoryPath('custom-cakes');
const url = categoryUrl('custom-cakes');

const listItems = [category.signature, ...category.variations].map((variation) => ({
  name: variation.name,
  description: variation.crave,
  image: `${SITE_ORIGIN}${variation.image.src}`,
}));

const jsonLd = [
  collectionPageSchema({ name: category.name, description: category.description, url }),
  itemListSchema(url, listItems),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE_ORIGIN}/` },
    { name: category.name, url },
  ]),
];
---

<Layout
	title={category.title}
	description={category.description}
	canonicalUrl={url}
	noIndex={false}
	jsonLd={jsonLd}
>
	<main class:list={['category-page', category.accent.theme]}>
		<Breadcrumbs trail={[{ name: 'Home', url: '/' }, { name: category.name, url: path }]} />

		<header class="intro content-shell">
			<p class="intro__eyebrow" data-reveal>Custom cakes &middot; Klang Valley</p>
			<h1 class="intro__title" data-reveal>{category.h1}</h1>
			<div class="intro__lead" data-reveal>
				{category.intro.map((paragraph) => (
					<p>{paragraph}</p>
				))}
			</div>
		</header>

		<SignatureBand
			image={category.signature.image}
			imageAlt={category.signature.imageAlt}
			eyebrow={category.signatureEyebrow}
			headline={category.signatureHeadline}
			crave={category.signature.crave}
			ctaLabel="Start your cake on WhatsApp"
			whatsappMessage={category.whatsappMessage}
			interest={category.modalInterest}
		/>

		<Collage
			heading="Made to order, made to your moment"
			intro="A few of the cakes we are asked for most. Yours is baked fresh for one date — tell us the flavour and the finish, and we shape it around your celebration."
			variations={category.variations}
		/>

		<section class="usecases">
			<div class="content-shell">
				<div class="usecases__panel" data-reveal>
					<h2 class="usecases__title">One baker, every kind of celebration</h2>
					<ul class="usecases__tags">
						{category.useCases.map((useCase) => (
							<li class="usecases__tag">{useCase}</li>
						))}
					</ul>
					<p class="usecases__note">{category.leadTimeNote}</p>
				</div>
			</div>
		</section>

		<CategoryCta
			variant="panel"
			heading="Have a date and a vision? Let's make the cake."
			body="Tell us your date and your idea on WhatsApp — we'll confirm flavours, design, and Lalamove delivery from there."
			label="Order on WhatsApp"
			whatsappMessage={category.whatsappMessage}
			interest={category.modalInterest}
		/>

		<RelatedLinks
			links={[
				{ label: 'Back to home', href: '/' },
				{
					label: 'Browse all our bakes',
					href: '/#categories',
					note: 'Cupcakes, pastries & cookies',
				},
			]}
		/>
	</main>
</Layout>

<style>
	.intro {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 60rem;
		padding-top: var(--space-xl);
		padding-bottom: var(--space-2xl);
	}

	.intro__eyebrow {
		font-size: var(--step--1);
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-strong);
	}

	.intro__lead {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 44rem;
		margin-top: var(--space-sm);
	}

	.intro__lead p {
		color: var(--color-text-muted);
	}

	.usecases {
		padding-top: var(--top-space-section-md);
		padding-bottom: var(--bottom-space-section-md);
	}

	.usecases__panel {
		padding: var(--space-2xl) var(--space-xl);
		border-radius: var(--radius-xl);
		background: var(--accent-tint);
	}

	.usecases__title {
		font-size: var(--header-two-font-size);
		max-width: 22ch;
		text-wrap: balance;
		margin-bottom: var(--space-lg);
	}

	.usecases__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		list-style: none;
		margin: 0 0 var(--space-xl);
		padding: 0;
	}

	.usecases__tag {
		padding: 0.5rem 1rem;
		border-radius: 999px;
		background: var(--white-bg);
		color: var(--accent-strong);
		font-weight: 600;
		font-size: var(--label-text-font-size);
	}

	.usecases__note {
		max-width: 54rem;
		font-size: var(--text-font-size);
	}
</style>
