---
import Landing from '../components/index/Landing.astro';
import { homeFaqs } from '../data/homeFaqs';
import Layout from '../layouts/Layout.astro';

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: homeFaqs.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

---

<Layout 
	title="Perlette Cakes | Home-based cakes and pastries in Klang Valley" 
	description="Perlette Cakes makes homemade custom cakes, cupcakes, pastries, and cookies for delivery across Klang Valley, Malaysia." 
	canonicalUrl="https://perlettecakes.com/" 
	noIndex={false}
	jsonLd={faqSchema} >
	<Landing />
</Layout>
