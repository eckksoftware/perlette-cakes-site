---
import { Image } from 'astro:assets';
import cupcakes from '../../assets/images/index/hero-cupcakes.JPG'
import floweryCake from '../../assets/images/index/hero-flowery-cake.JPG';
---

<section class="landing-hero__section" id="hero">
	<div class="landing-hero__inner content-shell">
		<div class="landing-hero__content">
			<h1 class="landing-hero__title">Baked by hand for moments you treasure</h1>
			<p class="landing-hero__summary">
				At Perlette Cakes we bake with love and care. Get cakes, cupcakes, pastries & cookies with a click of a button - WhatsApp.
			</p>
		</div>

		<div class="landing-hero__media-layout">
			<div class="landing-hero__media">
				<Image
					src={cupcakes}
					alt="An assortment of cupcakes made per order and customisable for personal or corporate events."
					loading="eager"
				/>
			</div>

			<div class="landing-hero__media">
				<Image
					src={floweryCake}
					alt="Flowery celebration cake with piped cream, edible flowers, and white ribbon detail."
					loading="eager"
				/>
			</div>
		</div>
	</div>
</section>

<style>
	.landing-hero__section {
		padding-bottom: var(--bottom-space-section-md);
	}

	.landing-hero__inner {
		display: flex;
		flex-direction: column;
	}

	.landing-hero__content {
		background-color: var(--pink-primary-bg);
		color: var(--white-text);
		padding: 40px 20px;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.landing-hero__title {
		font-size: 3rem;
		text-align: center;
		text-wrap: balance;
	}

	.landing-hero__summary {
		color: var(--white-text);
		text-align: left;
		border-top: 1px solid var(--white-bg);
		margin-top: var(--gap-space-md);
		padding-top: var(--gap-space-md);
	}

	.landing-hero__media-layout {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.landing-hero__media {
		width: 80%;
		padding: var(--top-space-media-md-mobile) 0;
	}

	.landing-hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 48rem) {
		.landing-hero__inner {
			position: relative;
		}

		.landing-hero__media-layout {
			display: flex;
			flex-direction: row;
			justify-content: space-between;
			flex-grow: 1;
		}

		.landing-hero__content {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			padding: 40px 20px;
			width: 50vw;
		}

		.landing-hero__title {
			font-size: 5rem;
		}

		.landing-hero__media {
			width: 35vw;
		}
	}
</style>
