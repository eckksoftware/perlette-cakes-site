---
import { Image } from 'astro:assets';
import strawberryCake from '../../assets/images/index/hero-strawberry-cake.JPG';
import cupcakes from '../../assets/images/index/hero-cupcakes.JPG'

interface Props {
  whatsappHref: string;
  instagramHref: string;
}

const { whatsappHref, instagramHref } = Astro.props;
---

<section class="landing-hero section-space" id="top">
	<div class="landing-hero__inner content-shell">
		<div class="landing-hero__media">
			<Image
				src={cupcakes}
				alt="An assortment of cupcakes made per order and customisable for personal or corporate events."
				loading="eager"
				width="800"
			/>
		</div>


		<div class="landing-hero__content">
			<h1 class="landing-hero__title">Cakes made by hand for moments you treasure</h1>
		</div>

		<div class="landing-hero__media">
			<Image
				src={strawberryCake}
				alt="Strawberry celebration cake with piped cream, fresh strawberries, and pink ribbon detail."
				loading="eager"
				width="800"
			/>
		</div>
	</div>
</section>

<style>
	.landing-hero {
		--hero-copy-max: 32rem;
		--hero-media-min-height: 35rem;
		padding-top: var(--space-lg);
	}

	.landing-hero__inner {
		display: flex;
		flex-direction: row;
		gap: var(--space-xl);
	}

	.landing-hero__content {
		display: flex;
		align-items: center;
	}

	.landing-hero__title {
		font-size: 5rem;
		text-align: center;
		text-wrap: balance;
	}

	.landing-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
	}

	.landing-hero__link {
		color: var(--color-primary-ink);
		font-size: var(--step--1);
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.landing-hero__facts {
		font-size: var(--step--1);
		line-height: 1.7;
	}

	.landing-hero__media {
		max-width: 80%;
	}

	.landing-hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

