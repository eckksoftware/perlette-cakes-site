---
import { Image } from 'astro:assets';
import strawberryCake from '../../assets/images/index/strawberry-cake.JPG';

interface Props {
  whatsappHref: string;
  instagramHref: string;
}

const { whatsappHref, instagramHref } = Astro.props;
---

<section class="landing-hero section-space" id="top">
	<div class="landing-hero__inner content-shell">
		<div class="landing-hero__content">
			<p class="eyebrow">Home-based baker in Klang Valley, Malaysia</p>
			<h1 class="landing-hero__title">Where every cake feels like a celebration</h1>
			<p class="landing-hero__summary text-muted">
				We make custom cakes, cupcakes, cookies, and pastries for delivery across Klang Valley, with every order starting on WhatsApp.
			</p>
			<div class="landing-hero__actions">
				<a class="button button--primary" href={whatsappHref} target="_blank" rel="noreferrer" data-order-trigger>
					Order on WhatsApp
				</a>
				<a class="landing-hero__link" href={instagramHref} target="_blank" rel="noreferrer">
					View Instagram
				</a>
			</div>
			<p class="landing-hero__facts text-muted">
				Order via WhatsApp, give 3 to 5 days notice, and receive delivery through Lalamove across Klang Valley.
			</p>
		</div>

		<div class="landing-hero__media">
			<Image
				src={strawberryCake}
				alt="Strawberry celebration cake with piped cream, fresh strawberries, and pink ribbon detail."
				loading="eager"
				width="800"
			/>
		</div>
	</div>
</section>

<style>
	.landing-hero {
		--hero-title-max: 8ch;
		--hero-copy-max: 32rem;
		--hero-media-min-height: 35rem;
		padding-top: var(--space-lg);
	}

	.landing-hero__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.landing-hero__content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-lg);
	}

	.landing-hero__title {
		max-width: var(--hero-title-max);
		font-size: clamp(3rem, 8vw, 5.25rem);
		line-height: 0.92;
		letter-spacing: -0.05em;
		text-wrap: balance;
	}

	.landing-hero__summary,
	.landing-hero__facts {
		max-width: var(--hero-copy-max);
	}

	.landing-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
	}

	.landing-hero__link {
		color: var(--color-primary-ink);
		font-size: var(--step--1);
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.landing-hero__facts {
		font-size: var(--step--1);
		line-height: 1.7;
	}

	.landing-hero__media {
		overflow: hidden;
		background: var(--color-surface-soft);
		aspect-ratio: 4 / 5;
		border-radius: var(--radius-xl);
	}

	.landing-hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 64rem) {
		.landing-hero {
			padding-top: var(--space-md);
		}

		.landing-hero__inner {
			display: grid;
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
			gap: var(--space-2xl);
			align-items: center;
		}

		.landing-hero__content {
			padding-block: var(--space-xl);
		}

		.landing-hero__media {
			aspect-ratio: auto;
			min-height: var(--hero-media-min-height);
		}
	}
</style>
