---
import { Image } from 'astro:assets';
import strawberryCake from '../../assets/images/index/strawberry-cake.JPG';

const whatsappHref = `https://wa.me/60196505050?text=${encodeURIComponent("Hi Perlette Cakes! I'd like to enquire about a custom cake order.")}`;
---

<main>
	<section class="landing-hero">
		<div class="landing-hero__inner content-shell">
			<div class="landing-hero__content">
				<p class="eyebrow">Home-based baker in Klang Valley, Malaysia</p>
				<h1 class="landing-hero__title">Where every cake feels like a celebration</h1>
				<p class="landing-hero__summary text-muted">
					Perlette Cakes makes custom cakes, cupcakes, cookies, and pastries for Klang Valley delivery, with every order started on WhatsApp.
				</p>
				<div class="landing-hero__actions">
					<a class="button button--primary" href={whatsappHref} target="_blank" rel="noreferrer">
						Order on WhatsApp
					</a>
					<a
						class="landing-hero__link"
						href="https://www.instagram.com/perlettecakes"
						target="_blank"
						rel="noreferrer"
					>
						View Instagram
					</a>
				</div>
			</div>

			<div class="landing-hero__media">
				<Image
					class="landing-hero__image"
					src={strawberryCake}
					alt="Strawberry celebration cake with piped cream, fresh strawberries, and pink ribbon detail."
					loading="eager"
					width="800"
				/>
			</div>
		</div>
	</section>
</main>

<style>
	.landing-hero {
		padding-block: var(--space-lg) var(--space-2xl);
	}

	.landing-hero__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.landing-hero__content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-lg);
	}

	.landing-hero__title {
		max-width: 9ch;
		font-size: clamp(3rem, 9vw, 5.5rem);
		line-height: 0.9;
		letter-spacing: -0.05em;
		text-wrap: balance;
	}

	.landing-hero__summary {
		max-width: 30rem;
		font-size: var(--step-0);
	}

	.landing-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		align-items: center;
	}

	.landing-hero__link {
		color: var(--color-primary-ink);
		font-size: var(--step--1);
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.landing-hero__media {
		overflow: hidden;
		background: var(--color-surface-soft);
		aspect-ratio: 4 / 5;
		border-radius: var(--radius-xl);
	}

	.landing-hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 64rem) {
		.landing-hero {
			padding-top: var(--space-md);
			padding-bottom: var(--space-xl);
		}

		.landing-hero__inner {
			display: grid;
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
			gap: var(--space-2xl);
			align-items: center;
		}

		.landing-hero__content {
			padding-block: var(--space-xl);
		}

		.landing-hero__media {
			aspect-ratio: auto;
			min-height: 34rem;
		}
	}
</style>
