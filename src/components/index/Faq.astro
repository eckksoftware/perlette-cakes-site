---
import { homeFaqs } from '../../data/homeFaqs';

interface Props {
  whatsappHref: string;
}

const { whatsappHref } = Astro.props;
---

<section class="faq" id="faq">
	<div class="faq__inner content-shell">
		<div class="faq__intro">
			<h2 class="faq__title">Common questions before you place a WhatsApp order</h2>
			<p class="text-muted">
				These are the main delivery, dietary, and order-policy details customers usually ask before confirming a cake or pastry delivery in Klang Valley.
			</p>
		</div>

		<div class="faq__grid">
			{homeFaqs.map((item, index) => (
				<details class="faq__item" open={index === 0}>
					<summary class="faq__summary">
						<span class="faq__question">{item.question}</span>
						<span class="faq__chevron" aria-hidden="true">v</span>
					</summary>
					<div class="faq__answer">
						<p class="text-muted">{item.answer}</p>
					</div>
				</details>
			))}
		</div>

		<p class="faq__note">
			If your order needs more specific timing, flavour, or dietary clarification, continue the conversation on
			<a href={whatsappHref} target="_blank" rel="noreferrer" data-order-trigger> WhatsApp</a>.
		</p>
	</div>
</section>

<style>
	.faq {
		background: linear-gradient(180deg, transparent 0%, var(--color-surface-soft) 100%);
		padding-top: var(--top-space-section-md);
		padding-bottom: var(--bottom-space-section-s);
	}

	.faq__inner,
	.faq__intro {
		display: flex;
		flex-direction: column;
	}

	.faq__inner {
		gap: var(--gap-space-xl);
	}

	.faq__intro {
		gap: var(--gap-space-md);
	}

	.faq__title {
		font-size: var(--header-two-font-size);
		text-wrap: balance;
	}

	.faq__grid {
		display: grid;
		gap: var(--space-lg);
	}

	.faq__item {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		overflow: hidden;
	}

	.faq__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		padding: var(--space-lg);
		cursor: pointer;
		list-style: none;
	}

	.faq__summary::-webkit-details-marker {
		display: none;
	}

	.faq__question {
		display: inline-block;
		font-size: var(--header-three-font-size);
		line-height: 1;
		font-family: var(--font-display);
		letter-spacing: -0.04em;
	}

	.faq__chevron {
		flex-shrink: 0;
		font-size: 1.4rem;
		font-weight: 700;
		transition: transform var(--transition-base);
		transform-origin: center;
	}

	.faq__item[open] .faq__chevron {
		transform: rotate(180deg);
	}

	.faq__answer {
		padding: 0 var(--space-lg) var(--space-lg);
	}

	.faq__note {
		font-size: var(--text-font-size);
		line-height: 1.7;
	}

	.faq__note a {
		color: var(--color-primary-ink);
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	@media (min-width: 48rem) {
		.faq__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
