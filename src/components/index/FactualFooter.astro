---
interface Props {
  whatsappHref: string;
  instagramHref: string;
}

const { whatsappHref, instagramHref } = Astro.props;
---

<footer class="factual-footer" id="footer">
	<div class="factual-footer__inner content-shell">
		<div class="factual-footer__closing">
			<div class="factual-footer__brand-block">
				<p class="factual-footer__brand">perlette cakes</p>
				<p class="text-muted">Home-based cakes and pastries for delivery across Klang Valley, Malaysia.</p>
			</div>

			<div class="factual-footer__actions">
				<a class="button button--primary" href={whatsappHref} target="_blank" rel="noreferrer" data-order-trigger>
					Order on WhatsApp
				</a>
				<a class="factual-footer__link" href={instagramHref} target="_blank" rel="noreferrer">
					Instagram
				</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.factual-footer {
		padding-block: var(--space-xl);
		background: var(--color-text);
		color: var(--color-surface);
	}

	.factual-footer__inner,
	.factual-footer__closing {
		display: flex;
		flex-direction: column;
	}

	.factual-footer :global(.text-muted) {
		color: rgba(255, 255, 255, 0.78);
	}

	.factual-footer__closing {
		gap: var(--space-lg);
	}

	.factual-footer__brand-block {
		max-width: 34rem;
	}

	.factual-footer__brand {
		margin-bottom: var(--space-xs);
		font-family: var(--font-display);
		font-size: var(--step-2);
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.04em;
		text-transform: lowercase;
	}

	.factual-footer__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
	}

	.factual-footer__link {
		color: var(--color-surface);
		font-size: var(--step--1);
		font-weight: 700;
		text-underline-offset: 0.25em;
	}

	.factual-footer__actions :global(.button--primary) {
		background: var(--color-surface);
		color: var(--color-primary-ink);
		box-shadow: none;
	}

	.factual-footer__actions :global(.button--primary:hover) {
		background: var(--color-surface-soft);
	}

	@media (min-width: 64rem) {
		.factual-footer__closing {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
