---
interface Props {
  whatsappHref: string;
}

const { whatsappHref } = Astro.props;
---

<section class="whatsapp-cta" id="contact">
	<div class="whatsapp-cta__inner content-shell">
		<div class="whatsapp-cta__panel">
			<div class="whatsapp-cta__copy">
				<h2 class="whatsapp-cta__title">Ready to ask about a cake, dessert box, or celebration order?</h2>
				<p>
					Fill in your delivery details, then we will continue the rest of the order conversation with you on WhatsApp.
				</p>
			</div>
			<a class="button whatsapp-cta__button" href={whatsappHref} target="_blank" rel="noreferrer" data-order-trigger>
				Open WhatsApp
			</a>
		</div>
	</div>
</section>

<style>
	.whatsapp-cta {
		padding-top: var(--top-space-section-md);
		padding-bottom: var(--bottom-space-section-md);
	}

	.whatsapp-cta__panel,
	.whatsapp-cta__copy {
		display: flex;
		flex-direction: column;
	}

	.whatsapp-cta__panel {
		gap: var(--space-xl);
		padding: var(--space-xl);
		border-radius: var(--radius-xl);
		background: var(--pink-primary-bg);
		color: var(--white-text);
	}

	.whatsapp-cta__copy {
		gap: var(--space-md);
		max-width: 36rem;
	}

	.whatsapp-cta__title {
		font-size: var(--header-two-font-size);
		text-wrap: balance;
	}

	.whatsapp-cta__button {
		align-self: flex-start;
		color: var(--pink-primary-bg);
		background-color: var(--white-text);
		box-shadow: none;
	}

	@media (min-width: 64rem) {
		.whatsapp-cta__panel {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
