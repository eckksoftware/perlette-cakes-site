---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import CategoryCta from './CategoryCta.astro';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  eyebrow?: string;
  headline: string;
  crave: string;
  ctaLabel: string;
  whatsappMessage: string;
  interest?: string;
}

const { image, imageAlt, eyebrow, headline, crave, ctaLabel, whatsappMessage, interest } =
  Astro.props;
---

<section class="signature">
	<div class="signature__media" data-parallax="0.1">
		<Image
			src={image}
			alt={imageAlt}
			loading="eager"
			fetchpriority="high"
			widths={[720, 1080, 1600, 2000]}
			sizes="100vw"
			quality={72}
		/>
	</div>

	<div class="signature__overlay">
		<div class="signature__panel content-shell" data-reveal>
			{eyebrow && <p class="signature__eyebrow">{eyebrow}</p>}
			<h2 class="signature__headline">{headline}</h2>
			<p class="signature__crave">{crave}</p>
			<CategoryCta
				variant="onImage"
				label={ctaLabel}
				whatsappMessage={whatsappMessage}
				interest={interest}
			/>
		</div>
	</div>
</section>

<style>
	.signature {
		position: relative;
		display: flex;
		width: 100%;
		min-height: min(86vh, 820px);
		overflow: hidden;
	}

	.signature__media {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.signature__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: translate3d(0, var(--parallax, 0px), 0) scale(1.12);
		will-change: transform;
	}

	.signature::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			to top,
			rgba(20, 12, 16, 0.78),
			rgba(20, 12, 16, 0.28) 55%,
			rgba(20, 12, 16, 0.05)
		);
	}

	.signature__overlay {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: flex-end;
		width: 100%;
		padding-block: var(--space-2xl);
	}

	.signature__panel {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 46rem;
		color: var(--white-text);
	}

	.signature__eyebrow {
		font-size: var(--step--1);
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(255, 253, 251, 0.82);
	}

	.signature__headline {
		font-size: var(--header-one-font-size);
		line-height: 0.95;
		text-wrap: balance;
	}

	.signature__crave {
		max-width: 34rem;
		color: rgba(255, 253, 251, 0.92);
	}
</style>
